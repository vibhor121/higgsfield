generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  credits   Int      @default(100)
  createdAt DateTime @default(now())
  videos    Video[]
}

model Video {
  id        String      @id @default(uuid())
  userId    String
  title     String
  prompt    String
  modelId   String
  status    VideoStatus @default(PENDING)
  url       String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
