generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  credits   Int      @default(100)
  createdAt DateTime @default(now())

  avatars      Avatar[]
  avatarVideos AvatarVideo[]
}

model Avatar {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user       User                   @relation(fields: [userId], references: [id])
  images     AvatarImage[]
  references AvatarVideoReference[]
}

model AvatarImage {
  id        String          @id @default(uuid())
  avatarId  String
  type      AvatarImageType
  url       String
  createdAt DateTime        @default(now())

  avatar Avatar @relation(fields: [avatarId], references: [id])
}

enum AvatarImageType {
  FACE
  FULL_BODY
  STYLE_REFERENCE
  GENERATED
}

model AvatarVideo {
  id         String      @id @default(uuid())
  userId     String
  prompt     String
  startFrame String?
  endFrame   String?
  duration   Int
  width      Int
  height     Int
  status     VideoStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  user       User                   @relation(fields: [userId], references: [id])
  references AvatarVideoReference[]
}

model AvatarVideoReference {
  id            String @id @default(uuid())
  avatarVideoId String
  avatarId      String

  avatarVideo AvatarVideo @relation(fields: [avatarVideoId], references: [id])
  avatar      Avatar      @relation(fields: [avatarId], references: [id])
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
